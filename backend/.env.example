# Application
APP_NAME=Zorvyn Finance API
APP_VERSION=1.0.0
DEBUG=False

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/zorvyn_finance

# For Docker, use: postgresql://user:password@postgres:5432/zorvyn_finance

# JWT
SECRET_KEY=your-secret-key-change-in-production-use-strong-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://finance-dashboard.vercel.app
